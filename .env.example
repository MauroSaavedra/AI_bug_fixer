# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════
# LLM Provider Selection
# ═══════════════════════════════════════════════════════════════════════════
# Choose your LLM provider: "openai" or "ollama"
LLM_PROVIDER=openai

# ═══════════════════════════════════════════════════════════════════════════
# OpenAI Configuration (if LLM_PROVIDER=openai)
# ═══════════════════════════════════════════════════════════════════════════
# Your OpenAI API key - get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI model to use
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# Optional: Custom base URL (for Azure OpenAI or proxies)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Temperature for sampling (0.0-2.0, lower = more deterministic)
OPENAI_TEMPERATURE=0.1

# Maximum tokens per response
OPENAI_MAX_TOKENS=4096

# ═══════════════════════════════════════════════════════════════════════════
# Ollama Configuration (if LLM_PROVIDER=ollama)
# ═══════════════════════════════════════════════════════════════════════════
# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use (must be pulled locally first: ollama pull llama3.2)
# Recommended for code: llama3.2, codellama, codellama:13b
OLLAMA_MODEL=llama3.2

# Temperature for sampling
OLLAMA_TEMPERATURE=0.1

# Request timeout in seconds
OLLAMA_TIMEOUT=120

# ═══════════════════════════════════════════════════════════════════════════
# LangSmith Observability Configuration (Optional)
# ═══════════════════════════════════════════════════════════════════════════
# Enable tracing: https://smith.langchain.com/
# Sign up for free at https://smith.langchain.com/ to get API key
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls-your-api-key-here
LANGCHAIN_PROJECT=agentic-source

# ═══════════════════════════════════════════════════════════════════════════
# Vector Store Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Path to ChromaDB database
CHROMA_DB_PATH=./chroma_db

# Collection name for code entities
CHROMA_COLLECTION=agentic_source_repo

# Number of similar chunks to retrieve (1-20)
CHROMA_SIMILARITY_TOP_K=5

# ═══════════════════════════════════════════════════════════════════════════
# Bug Detection Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Tools to use for detection: mypy,pylint,ruff (comma-separated)
DETECTION_TOOLS=["mypy","pylint","ruff"]

# ═══════════════════════════════════════════════════════════════════════════
# Orchestration Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Maximum retry attempts when fix is rejected (0-10)
MAX_RETRIES=3

# Enable streaming responses (if supported by LLM)
ENABLE_STREAMING=false

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
